# Example env file. Copy to .env and fill real values. NEVER commit .env.
# Agents in this project are forbidden from reading .env and .env.*.
# Pattern: NAME=<replace>

# --- Core runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Database (if __DATABASE__ uses env) ---
DATABASE_URL=<replace>

# --- Frontend (if __FRONTEND__ exposes env) ---
VITE_PUBLIC_API_URL=http://localhost:3000

# --- Agent cost tracking (optional) ---
# ANTHROPIC_API_KEY=<prefer CLI login via 'claude' rather than env>
